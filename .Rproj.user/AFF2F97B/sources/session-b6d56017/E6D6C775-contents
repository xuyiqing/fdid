# Load the FDID package
library(fdid)

# Load the dataset
library(haven)
library(dplyr)
d <- as.data.frame(read.csv("long_format_data.csv"))

# Prepare data
start <- 1954
d$provid <- as.factor(d$provid)
d$highzupu <- ifelse(d$pczupu >= median(d$pczupu, na.rm = TRUE), 1, 0)

# Define parameters
treat <- "highzupu"
Y <- "mortality"
time <- "year"
unit <- "provid"
period <- start:1966
tr_period <- 1958:1961
covar <- c("avggrain", "nograin", "urban", "dis_bj", "dis_pc", "rice", "minority", "edu", "lnpop")

# Prepare the data for FDID
prepared_data <- fdid_prepare(
  data = d,
  Y = Y,
  X = covar,
  G = treat,
  unit_label = unit,
  time_label = time,
  treat_periods = period
)

# Estimate effects using FDID
fdid_results <- fdid(prepared_data, method = "did")

# Summary of the results
print(summary(fdid_results))

# Plot raw means
pdf("famine_raw.pdf", height = 5, width = 8)
plot.fdid(prepared_data, type = "raw")
dev.off()

# Plot overlap of propensity scores
pdf("ps_overlap.pdf", height = 5, width = 7)
plot.fdid(prepared_data, type = "overlap")
dev.off()

# Perform dynamic FDID analysis
fdid_dyn_results <- fdid_dyn(prepared_data, method = "ols1")

# Plot dynamic estimates
pdf("dynamic_estimates.pdf", height = 5, width = 8)
plot.fdid(fdid_dyn_results, type = "dynamic")
dev.off()
