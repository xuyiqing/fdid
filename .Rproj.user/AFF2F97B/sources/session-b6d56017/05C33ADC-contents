est.dyn <- function(data, Y, treat, covar, period, base.period, estimator = "lin") {
  TT <- length(period)
  Ys <- paste0(Y, period)
  out <- matrix(NA, TT, 4) # est, se, ci1, ci2
  rownames(out) <- period
  colnames(out) <- c("est", "se", "ci_l", "ci_h")
  for (i in 1:TT) {
    if (period[i] == base.period) {
      out[i, ] <- c(0, 0, 0, 0)
      next
    }
    if (length(base.period)==1) {
      data[ ,"tempY"] <- data[, Ys[i]] - data[, paste0(Y,base.period)]
    } else {
      data[ ,"tempY"] <- data[, Ys[i]] - rowMeans(data[, paste0(Y,base.period)])
    }
    if (estimator == "aipw") {
      out[i, ] <- aipw(data, "tempY", treat, covar)
    }
    if (estimator == "diff") {
      out[i, ] <- diff(data, "tempY", treat)
    }
    if (estimator == "twfe1") {
      out[i, ] <- reg(data, "tempY", treat, covar)
    }
    if (estimator == "twfe2") {
      out[i, ] <- om.reg(data, "tempY", treat, covar)
    }
    if (estimator == "ipw") {
      out[i, ] <- ipw(data, "tempY", treat, covar)
    }
    if (estimator == "lin") {
      out[i, ] <- lin(data, "tempY", treat, covar)
    }
  }
  return(out)
}

# bootstrap wrapper around est.dyn
