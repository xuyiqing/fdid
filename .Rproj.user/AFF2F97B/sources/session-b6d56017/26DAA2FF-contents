plot.means <- function(data, Y, treat, time, period, tr_period, labels = NULL) {
  if (is.null(labels)==TRUE) {
    labels <- c("With Genealogies", "Without Genealogies")
  }
  par(mar = c(4, 4, 1, 1))
  d <- data
  TT <- length(period)
  mean1 <- mean0 <- rep(0, TT)
  for (i in 1:TT) {
    mean1[i] <- mean(d[which(d[, treat]==1), paste0(Y,period[i])], na.rm = TRUE)
    mean0[i] <- mean(d[which(d[, treat]==0), paste0(Y,period[i])], na.rm = TRUE)
  }
  out <- cbind.data.frame(time = period, Y0 = mean0, Y1 = mean1)
  plot(out[,1], out[, 2], type = "n", ylim = c(0, 40), 
       xlab = "Year", ylab = "Deaths per 1,000 People")
  trp1 <- min(tr_period)
  trp2 <- max(tr_period)
  rect(trp1-0.5, -2, trp2+0.5, 100, col = "#AAAAAA50", border = FALSE)
  box()
  lines(out[,1], out[, 2], type = "l", col = 4, lty = 2, lwd = 1.5)
  lines(out[,1], out[, 3], type = "l", col = 1, lwd = 1.2)
  points(out[,1], out[, 2], pch = 17, col = 4)
  points(out[,1], out[, 3], pch = 16, col = 1, cex = 1.2)
  legend("topright",labels,cex=1.2, col = c(1, 4), 
         pch = c(16, 17), seg.len=1,bty="n")
  text(1959.5, 38, "Famine", cex = 1.2, col = "gray30")
}


