## estimate all
est.all <- function(data, Y, treat, covar, ref_period, tr_period,
    methods = c("diff", "reg", "lin")) {

  Y.raw <- Y
  Y_exposed <- paste0(Y, tr_period)
  Y_reference <- paste0(Y, ref_period)
  if (length(ref_period) == 1) {
    data[, Y] <- rowMeans(data[, Y_exposed]) - data[, Y_reference]
  } else {
    data[, Y] <- rowMeans(data[, Y_exposed]) - rowMeans(data[, Y_reference])
  }

  results <- as.data.frame(matrix(NA, length(methods), 4))
  rownames(results) <- methods
  colnames(results) <- c("Estimate", "SE", "CI_lower", "CI_upper")
  m <- 1
  if ("diff" %in% methods) {
    results[m, ] <- diff(data, Y, treat)
    m <- m + 1
  }
  if ("reg" %in% methods) {
    results[m, ] <- reg(data, Y, treat, covar)
    m <- m + 1
  }
  if ("lin" %in% methods) {
    results[m, ] <- lin(data, Y, treat, covar)
    m <- m + 1
  }
  return(results)
}


# bootstrap wrapper around est.dyn
est.all.boot <- function(data, Y, treat, covar, ref_period, tr_period, methods = c("diff", "reg", "lin"),
  nsim = 1000, parallel = TRUE, cores = 10) {

  # point estimate
  est <- est.all(data, Y, treat, covar, ref_period, tr_period, methods)[,1]

  one.boot <- function() {
    data.boot <- data[sample(1:nrow(data), replace = TRUE), ]
    return(est.all(data.boot, Y, treat, covar, ref_period, tr_period, methods)[,1])
  }

  if (parallel == FALSE) {
    boot.out <- matrix(NA, nsim, TT)
    for (i in 1:nsim) {
      boot.out[i,] <- one.boot()
      if (i %% 100 == 0) {cat(".")}
    }
  } else { # parallel computing
    library(future)
    library(doParallel)
    cl2 <- future::makeClusterPSOCK(cores, verbose = F)
    doParallel::registerDoParallel(cl2)
    boot.out <- foreach (i=1:nsim,.combine=rbind,.inorder=FALSE,
      .export = c("diff", "reg", "lin", "est.all"),
      .packages = c("estimatr", "car")) %dopar% {
      return(one.boot())
    }
    stopCluster(cl2)
  }
  # summarize
  se <- apply(boot.out, 2, sd)
  ci <- t(apply(boot.out, 2, function(x) quantile(x, probs = c(0.025, 0.975))))
  out <- cbind.data.frame(est, se, ci)
  colnames(out) <- c("est", "se", "ci_l", "ci_h")
  return(out)
}





