library(estimatr)


# difference in means
diff <- function(data, Y, treat) {
    #data <- data[complete.cases(data[, c(Y, treat)]),]
    fml <- as.formula(paste(Y, "~", treat))
    out <- summary(lm_robust(fml, data = data, se_type = "stata"))$coefficients[treat, c(1, 2, 5, 6)]
    return(out) # extract coef, se, ci.lower, ci.upper
}


# regression adjustment
reg <- function(data, Y, treat, covar) {
    #data <- data[complete.cases(data[, c(Y, treat, covar)]),]
    fml <- as.formula(paste(Y, "~", treat, "+", paste(covar, collapse = " + ")))
    out <- summary(lm_robust(fml, data = data, se_type = "stata"))$coefficients[treat, c(1, 2, 5, 6)]
    # extract coef, se, ci.lower, ci.upper
    return(out)
}

# Lin estimator
lin <- function(data, Y, treat, covar){
  ## treatment and outcome
  Z = data[, treat]
  Y = data[, Y]
  ## standardize covariates
  X = data[, covar]
  X = scale(X)
  n = dim(X)[1]
  p = dim(X)[2]

  ## fully interacted OLS
  linreg = lm(Y ~ Z * X)
  est    = coef(linreg)[2]
  vehw   = car::hccm(linreg)[2, 2]

  ## super population correction
  inter  = coef(linreg)[(p+3):(2*p+2)]
  sesuper = sqrt(vehw + sum(inter*(cov(X)%*%inter))/n)

  out <- c(est, sesuper, est - 1.96*sesuper, est + 1.96*sesuper)
  return(out)
}



