plot.dyn <- function(out, ylim, tr_period, main = "") {
  par(mar = c(4, 4, 1, 1))
  period <- rownames(out)
  plot(period, out[, 1], type = "n", ylim = ylim, 
       xlab = "Year", ylab = "Estimated Coefficient (w/ 95% CI)", main = main)
  trp1 <- min(tr_period)
  trp2 <- max(tr_period)
  rect(trp1-0.5, ylim[1]-1, trp2+0.5, ylim[2]+1, col = "#AAAAAA50", border = FALSE)
  box()
  abline(h = 0, col = "gray", lwd = 2, lty = 2)
  for (i in 1:nrow(out)) {
    lines(c(period[i], period[i]), c(out[i,3], out[i,4]))
  }
  points(period, out[, 1], pch = 16)
  text(1959.5, ylim[2]-1, "Famine", cex = 1.2, col = "gray30")
}
